{
  "petTypeId": "ginger-cat",
  "callOutAnimation": "walk",
  "goToSleepAnimation": "walk",
  "followAnimation": "walk",
  "dragOffset": { "x": 20, "y": 20 },
  "animations": {
    "idle": {
      "movementSpeed": { "x": 0, "y": 0 },
      "wanderRules": {
        "minSeconds": 5,
        "maxSeconds": 10,
        "nextIntent": ["walk", "sit"],
        "canTurn": true
      },
      "animationTransitions": {
        "walk": "idle-to-walk",
        "sit": "idle-to-sit"
      }
    },
    "sleep": {
      "movementSpeed": { "x": 0, "y": 0 },
      "animationTransitions": {
        "lounge": "sleep-to-lounge"
      }
    },
    "none": {
      "movementSpeed": { "x": 0, "y": 0 },
      "wanderRules": {
        "minSeconds": 2,
        "maxSeconds": 5,
        "nextIntent": ["idle"],
        "canTurn": false
      }
    },
    "walk": {
      "movementSpeed": { "x": 0.8, "y": 0 },
      "wanderRules": {
        "minSeconds": 3,
        "maxSeconds": 8,
        "nextIntent": ["idle", "sit"],
        "canTurn": true
      },
      "animationTransitions": {
        "idle": "walk-to-idle",
        "sit": "idle-to-sit"
      }
    },
    "sit": {
      "movementSpeed": { "x": 0, "y": 0 },
      "wanderRules": {
        "minSeconds": 10,
        "maxSeconds": 20,
        "nextIntent": ["idle", "lounge", "walk", "sit&lookBack"],
        "canTurn": false
      },
      "animationTransitions": {
        "idle": "sit-to-idle",
        "lounge": "sit-to-lounge",
        "walk": "sit-to-idle",
        "sit&lookBack": "sit-to-sit&lookBack"
      }
    },
    "groom": {
      "movementSpeed": { "x": 0, "y": 0 },
      "wanderRules": {
        "minSeconds": 4,
        "maxSeconds": 10,
        "nextIntent": ["lounge"],
        "canTurn": false
      },
      "animationTransitions": {
        "lounge": "groom-to-lounge"
      }
    },
    "lounge": {
      "movementSpeed": { "x": 0, "y": 0 },
      "wanderRules": {
        "minSeconds": 4,
        "maxSeconds": 10,
        "nextIntent": ["groom", "sit", "sleep", "lounge&lookBack"],
        "canTurn": false
      },
      "animationTransitions": {
        "groom": "lounge-to-groom",
        "sit": "lounge-to-sit",
        "sleep": "lounge-to-sleep",
        "lounge&lookBack": "lounge-to-lounge&lookBack"
      }
    },
    "lounge&lookBack": {
      "movementSpeed": { "x": 0, "y": 0 },
      "wanderRules": {
        "minSeconds": 4,
        "maxSeconds": 10,
        "nextIntent": ["lounge"],
        "canTurn": false
      },
      "animationTransitions": {
        "lounge": "lounge&lookBack-to-lounge"
      }
    },
    "sit&lookBack": {
      "movementSpeed": { "x": 0, "y": 0 },
      "wanderRules": {
        "minSeconds": 4,
        "maxSeconds": 10,
        "nextIntent": ["sit"],
        "canTurn": false
      },
      "animationTransitions": {
        "sit": "sit&lookBack-to-sit"
      }
    }
  }
}
